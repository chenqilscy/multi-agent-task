{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Agent 调用总量",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(maf_agent_executions_total[1h]))",
          "legendFormat": "调用次数"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Agent 成功率",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(maf_agent_executions_total{status=\"success\"}[5m])) / sum(rate(maf_agent_executions_total[5m])) * 100",
          "legendFormat": "成功率"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "title": "Agent 平均响应时间",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(maf_agent_execution_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "title": "活跃 Agent 数量",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(count by (agent_name)(maf_agent_executions_total))",
          "legendFormat": "Agent 数"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Agent 调用速率（按名称）",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(maf_agent_executions_total[5m])) by (agent_name)",
          "legendFormat": "{{agent_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "auto"
          }
        }
      }
    },
    {
      "title": "Agent 响应时间分布（按名称）",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(maf_agent_execution_duration_seconds_bucket[5m])) by (le, agent_name))",
          "legendFormat": "{{agent_name}} P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(maf_agent_execution_duration_seconds_bucket[5m])) by (le, agent_name))",
          "legendFormat": "{{agent_name}} P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(maf_agent_execution_duration_seconds_bucket[5m])) by (le, agent_name))",
          "legendFormat": "{{agent_name}} P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "title": "Agent 调用成功/失败（按名称）",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(maf_agent_executions_total{status=\"success\"}[1h])) by (agent_name)",
          "legendFormat": "{{agent_name}} 成功"
        },
        {
          "expr": "sum(increase(maf_agent_executions_total{status=\"failure\"}[1h])) by (agent_name)",
          "legendFormat": "{{agent_name}} 失败"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "stacking": { "mode": "normal" }
          }
        }
      }
    },
    {
      "title": "Agent 调用趋势（成功率%）",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(maf_agent_executions_total{status=\"success\"}[5m])) by (agent_name) / sum(rate(maf_agent_executions_total[5m])) by (agent_name) * 100",
          "legendFormat": "{{agent_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["cky-maf", "agent"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "CKY.MAF - Agent 监控",
  "uid": "maf-agent-dashboard",
  "version": 1
}
