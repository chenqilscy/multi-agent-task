using CKY.MultiAgentFramework.Core.Models.LLM;
using CKY.MultiAgentFramework.Repository.LLM;
using FluentAssertions;
using Microsoft.Extensions.Logging.Abstractions;
using Moq;

namespace CKY.MultiAgentFramework.Tests.LLM
{
    /// <summary>
    /// 智谱AI LLM Agent 单元测试
    /// </summary>
    public class ZhipuAILlmAgentTests
    {
        private readonly LlmProviderConfig _config;
        private readonly ZhipuAILlmAgent _sut;

        public ZhipuAILlmAgentTests()
        {
            _config = new LlmProviderConfig
            {
                ProviderName = "zhipuai",
                ProviderDisplayName = "智谱AI",
                ApiBaseUrl = "https://open.bigmodel.cn/api/",
                ApiKey = "test-api-key",
                ModelId = "glm-4",
                ModelDisplayName = "GLM-4",
                SupportedScenarios = new List<LlmScenario> { LlmScenario.Chat, LlmScenario.Embed, LlmScenario.Intent },
                MaxTokens = 2000,
                Temperature = 0.7,
                IsEnabled = true,
                Priority = 0
            };

            _sut = new ZhipuAILlmAgent(
                _config,
                NullLogger<ZhipuAILlmAgent>.Instance);
        }

        [Fact]
        public void Agent_ShouldInheritFromLlmAgent()
        {
            // Assert
            _sut.Should().BeAssignableTo<CKY.MultiAgentFramework.Core.Agents.LlmAgent>();
        }

        [Fact]
        public void Agent_ShouldHaveCorrectId()
        {
            // Assert
            _sut.Id.Should().Be("zhipuai-glm-4");
        }

        [Fact]
        public void Agent_ShouldHaveCorrectName()
        {
            // Assert
            _sut.Name.Should().Be("智谱AI (glm-4)");
        }

        [Fact]
        public void Agent_ShouldHaveCorrectDescription()
        {
            // Assert
            _sut.Description.Should().Contain("zhipuai");
            _sut.Description.Should().Contain("glm-4");
        }

        [Fact]
        public void SupportsScenario_ShouldReturnTrue_ForSupportedScenarios()
        {
            // Assert
            _sut.SupportsScenario(LlmScenario.Chat).Should().BeTrue();
            _sut.SupportsScenario(LlmScenario.Embed).Should().BeTrue();
            _sut.SupportsScenario(LlmScenario.Intent).Should().BeTrue();
        }

        [Fact]
        public void SupportsScenario_ShouldReturnFalse_ForUnsupportedScenarios()
        {
            // Assert
            _sut.SupportsScenario(LlmScenario.Image).Should().BeFalse();
            _sut.SupportsScenario(LlmScenario.Video).Should().BeFalse();
        }

        [Fact]
        public void Constructor_WithNullConfig_ShouldThrowArgumentNullException()
        {
            // Act & Assert
            Assert.Throws<ArgumentNullException>(() =>
                new ZhipuAILlmAgent(
                    null!,
                    NullLogger<ZhipuAILlmAgent>.Instance));
        }

        [Fact]
        public void Constructor_WithNullLogger_ShouldThrowArgumentNullException()
        {
            // Act & Assert
            Assert.Throws<ArgumentNullException>(() =>
                new ZhipuAILlmAgent(
                    _config,
                    null!));
        }

        [Fact]
        public void Constructor_ShouldValidateConfig()
        {
            // Act & Assert
            // 配置验证在构造函数中自动完成
            // 如果配置无效，会抛出 ArgumentException
            var act = () => new ZhipuAILlmAgent(
                _config,
                NullLogger<ZhipuAILlmAgent>.Instance);

            act.Should().NotThrow();
        }

        [Fact]
        public async Task ExecuteAsync_WithChatScenario_ShouldCallChatCompletion()
        {
