            // TODO: Implement HttpClient factory pattern for better testability

            // Act & Assert
            // Skipping actual implementation since HttpClient is created locally
            await Task.CompletedTask;
        }

        [Fact]
        public void GetApiKey_ShouldReturnConfiguredKey()
        {
            // Act
            var method = _sut.GetType().GetMethod("GetApiKey",
                System.Reflection.BindingFlags.NonPublic | System.Reflection.BindingFlags.Instance);

            // Assert
            method.Should().NotBeNull();
            var result = method?.Invoke(_sut, null);
            result.Should().Be("test-api-key");
        }

        [Fact]
        public void GetCurrentModelId_ShouldReturnConfiguredModelId()
        {
            // Act
            var method = _sut.GetType().GetMethod("GetCurrentModelId",
                System.Reflection.BindingFlags.NonPublic | System.Reflection.BindingFlags.Instance);

            // Assert
            method.Should().NotBeNull();
            var result = method?.Invoke(_sut, null);
            result.Should().Be("glm-4");
        }

        [Fact]
        public async Task ExecuteBatchAsync_ShouldReturnMultipleResults()
        {
            // Note: This test would require HttpClient mocking
