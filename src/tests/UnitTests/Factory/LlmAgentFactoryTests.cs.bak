using CKY.MultiAgentFramework.Core.Abstractions;
using CKY.MultiAgentFramework.Core.Models.LLM;
using Microsoft.Extensions.Logging;
using Moq;
using Xunit;

namespace CKY.MultiAgentFramework.Tests.Factory
{
    /// <summary>
    /// LlmAgentFactory 单元测试
    /// </summary>
    public class LlmAgentFactoryTests
    {
        private readonly Mock<ILlmProviderConfigRepository> _mockRepository;
        private readonly Mock<ILogger<LlmAgentFactory>> _mockLogger;
        private readonly Mock<ILoggerFactory> _mockLoggerFactory;

        public LlmAgentFactoryTests()
        {
            _mockRepository = new Mock<ILlmProviderConfigRepository>();
            _mockLogger = new Mock<ILogger<LlmAgentFactory>>();
            _mockLoggerFactory = new Mock<ILoggerFactory>();
        }

        [Fact]
        public async Task CreateAgentAsync_WithValidConfig_ReturnsAgent()
        {
            // Arrange
            var config = CreateTestConfig(
                providerName: "zhipuai",
                scenarios: new List<LlmScenario> { LlmScenario.Chat, LlmScenario.Intent });

            // Act
            var factory = new LlmAgentFactory(
                _mockLogger.Object,
                _mockRepository.Object,
                _mockLoggerFactory.Object);

            var agent = await factory.CreateAgentAsync(config, LlmScenario.Chat);

            // Assert
            Assert.NotNull(agent);
            Assert.Equal("zhipuai-glm-4", agent.AgentId);
            Assert.True(agent.SupportsScenario(LlmScenario.Chat));
        }

        [Fact]
        public async Task CreateAgentAsync_WithUnsupportedScenario_ThrowsException()
        {
            // Arrange
            var config = CreateTestConfig(
                providerName: "zhipuai",
                scenarios: new List<LlmScenario> { LlmScenario.Chat }); // 不支持 Embed

            var factory = new LlmAgentFactory(
                _mockLogger.Object,
                _mockRepository.Object,
                _mockLoggerFactory.Object);

            // Act & Assert
            var exception = await Assert.ThrowsAsync<InvalidOperationException>(
                () => factory.CreateAgentAsync(config, LlmScenario.Embed));

            Assert.Contains("does not support scenario", exception.Message);
        }

        [Fact]
        public async Task CreateAgentAsync_WithDisabledProvider_ThrowsException()
        {
            // Arrange
            var config = CreateTestConfig(
                providerName: "zhipuai",
                scenarios: new List<LlmScenario> { LlmScenario.Chat });
            config.IsEnabled = false;

            var factory = new LlmAgentFactory(
                _mockLogger.Object,
                _mockRepository.Object,
                _mockLoggerFactory.Object);

            // Act & Assert
            var exception = await Assert.ThrowsAsync<InvalidOperationException>(
                () => factory.CreateAgentAsync(config, LlmScenario.Chat));

            Assert.Contains("is disabled", exception.Message);
        }

        [Fact]
        public async Task CreateBestAgentForScenarioAsync_SelectsHighestPriorityAgent()
        {
            // Arrange
            var highPriorityConfig = CreateTestConfig(
                providerName: "zhipuai",
                priority: 1,
                scenarios: new List<LlmScenario> { LlmScenario.Chat });

            var lowPriorityConfig = CreateTestConfig(
                providerName: "tongyi",
                priority: 10,
                scenarios: new List<LlmScenario> { LlmScenario.Chat });

            _mockRepository
                .Setup(r => r.GetAllEnabledAsync(default))
                .ReturnsAsync(new List<LlmProviderConfig> { lowPriorityConfig, highPriorityConfig });

            var factory = new LlmAgentFactory(
                _mockLogger.Object,
                _mockRepository.Object,
                _mockLoggerFactory.Object);

            // Act
            var agent = await factory.CreateBestAgentForScenarioAsync(LlmScenario.Chat);

            // Assert
            Assert.NotNull(agent);
            Assert.Equal("zhipuai-glm-4", agent.AgentId); // 高优先级（Priority=1）
        }

        [Fact]
        public async Task CreateAllAgentsForScenarioAsync_ReturnsAllSupportingAgents()
        {
            // Arrange
            var chatOnlyConfig = CreateTestConfig(
                providerName: "zhipuai",
                scenarios: new List<LlmScenario> { LlmScenario.Chat });

            var multiScenarioConfig = CreateTestConfig(
                providerName: "tongyi",
                scenarios: new List<LlmScenario> { LlmScenario.Chat, LlmScenario.Embed });

            _mockRepository
                .Setup(r => r.GetAllEnabledAsync(default))
                .ReturnsAsync(new List<LlmProviderConfig> { chatOnlyConfig, multiScenarioConfig });

            var factory = new LlmAgentFactory(
                _mockLogger.Object,
                _mockRepository.Object,
                _mockLoggerFactory.Object);

            // Act
            var agents = await factory.CreateAllAgentsForScenarioAsync(LlmScenario.Chat);

            // Assert
            Assert.Equal(2, agents.Count);
            Assert.Contains(agents, a => a.AgentId == "zhipuai-glm-4");
            Assert.Contains(agents, a => a.AgentId == "tongyi-qwen-max");
        }

        [Fact]
        public async Task CreateAgentByProviderAsync_WithValidProvider_ReturnsAgent()
        {
            // Arrange
            var config = CreateTestConfig(
                providerName: "zhipuai",
                scenarios: new List<LlmScenario> { LlmScenario.Chat });

            _mockRepository
                .Setup(r => r.GetByNameAsync("zhipuai", default))
                .ReturnsAsync(config);

            var factory = new LlmAgentFactory(
                _mockLogger.Object,
                _mockRepository.Object,
                _mockLoggerFactory.Object);

            // Act
            var agent = await factory.CreateAgentByProviderAsync("zhipuai", LlmScenario.Chat);

            // Assert
            Assert.NotNull(agent);
            Assert.Equal("zhipuai-glm-4", agent.AgentId);
        }

        [Fact]
        public async Task IsScenarioSupportedAsync_WithSupportedScenario_ReturnsTrue()
        {
            // Arrange
            var config = CreateTestConfig(
                providerName: "zhipuai",
                scenarios: new List<LlmScenario> { LlmScenario.Chat, LlmScenario.Intent });

            _mockRepository
                .Setup(r => r.GetByNameAsync("zhipuai", default))
                .ReturnsAsync(config);

            var factory = new LlmAgentFactory(
                _mockLogger.Object,
                _mockRepository.Object,
                _mockLoggerFactory.Object);

            // Act
            var isSupported = await factory.IsScenarioSupportedAsync("zhipuai", LlmScenario.Chat);

            // Assert
            Assert.True(isSupported);
        }

        [Fact]
        public async Task IsScenarioSupportedAsync_WithUnsupportedScenario_ReturnsFalse()
        {
            // Arrange
            var config = CreateTestConfig(
                providerName: "zhipuai",
                scenarios: new List<LlmScenario> { LlmScenario.Chat }); // 不支持 Embed

            _mockRepository
                .Setup(r => r.GetByNameAsync("zhipuai", default))
                .ReturnsAsync(config);

            var factory = new LlmAgentFactory(
                _mockLogger.Object,
                _mockRepository.Object,
                _mockLoggerFactory.Object);

            // Act
            var isSupported = await factory.IsScenarioSupportedAsync("zhipuai", LlmScenario.Embed);

            // Assert
            Assert.False(isSupported);
        }

        #region 测试辅助方法

        private LlmProviderConfig CreateTestConfig(
            string providerName = "zhipuai",
            int priority = 0,
            List<LlmScenario>? scenarios = null)
        {
            return new LlmProviderConfig
            {
                ProviderName = providerName,
                ProviderDisplayName = providerName.ToUpper() + " Provider",
                ApiBaseUrl = $"https://api.{providerName}.com/",
                ApiKey = "test-api-key-12345",
                ModelId = providerName == "zhipuai" ? "glm-4" : "qwen-max",
                ModelDisplayName = providerName == "zhipuai" ? "GLM-4" : "Qwen Max",
                SupportedScenarios = scenarios ?? new List<LlmScenario> { LlmScenario.Chat },
                MaxTokens = 2000,
                Temperature = 0.7,
                IsEnabled = true,
                Priority = priority,
                CostPer1kTokens = 0.05m
            };
        }

        #endregion
    }
}
