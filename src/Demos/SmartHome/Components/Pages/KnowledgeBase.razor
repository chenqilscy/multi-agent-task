@page "/knowledge"
@using CKY.MultiAgentFramework.Core.Abstractions
@using CKY.MultiAgentFramework.Core.Models.RAG
@using CKY.MultiAgentFramework.Demos.SmartHome.Agents
@using CKY.MultiAgentFramework.Core.Models.Task
@rendermode InteractiveServer
@inject KnowledgeBaseAgent KnowledgeAgent
@inject IRagPipeline RagPipeline

<PageTitle>知识库 - 智能家居</PageTitle>

<div class="kb-container">
    <div class="kb-header">
        <h2>📚 智能家居知识库</h2>
        <p class="kb-subtitle">搜索常见问题、使用说明和功能介绍</p>
    </div>

    <div class="kb-search">
        <div class="search-box">
            <input @bind="searchQuery"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown"
                   placeholder="输入问题，例如：如何设置空调温度？"
                   disabled="@isSearching" />
            <button @onclick="Search"
                    disabled="@(string.IsNullOrWhiteSpace(searchQuery) || isSearching)">
                @(isSearching ? "⏳ 搜索中..." : "🔍 搜索")
            </button>
        </div>

        <div class="quick-questions">
            <span class="quick-label">常见问题：</span>
            <button class="quick-btn" @onclick="@(() => QuickSearch("如何控制灯光"))">💡 灯光控制</button>
            <button class="quick-btn" @onclick="@(() => QuickSearch("怎么使用空调"))">🌡️ 空调使用</button>
            <button class="quick-btn" @onclick="@(() => QuickSearch("安防功能介绍"))">🔒 安防功能</button>
            <button class="quick-btn" @onclick="@(() => QuickSearch("音乐播放功能"))">🎵 音乐播放</button>
            <button class="quick-btn" @onclick="@(() => QuickSearch("天气查询功能"))">🌤️ 天气查询</button>
        </div>
    </div>

    @if (searchResult != null)
    {
        <div class="kb-results">
            <div class="results-header">
                <h3>查询结果</h3>
                <span class="results-count">找到 @searchResult.RetrievedChunks.Count 条相关内容</span>
            </div>

            @if (searchResult.RetrievedChunks.Count > 0)
            {
                @foreach (var chunk in searchResult.RetrievedChunks)
                {
                    <div class="result-card">
                        <div class="result-meta">
                            <span class="result-source">📄 @chunk.DocumentId</span>
                            <span class="result-score">相似度: @chunk.Score.ToString("P0")</span>
                        </div>
                        <div class="result-content">@chunk.Content</div>
                    </div>
                }
            }
            else
            {
                <div class="no-results">
                    <div class="no-results-icon">🔍</div>
                    <p>未找到相关内容，请尝试其他关键词。</p>
                </div>
            }
        </div>
    }

    <div class="kb-stats">
        <h3>📊 知识库概况</h3>
        <div class="stats-grid">
            <div class="stat-card">
                <span class="stat-value">@knowledgeDocCount</span>
                <span class="stat-label">文档总数</span>
            </div>
            <div class="stat-card">
                <span class="stat-value">@searchCount</span>
                <span class="stat-label">本次搜索次数</span>
            </div>
        </div>
    </div>
</div>

<style>
    .kb-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 1.5rem;
    }

    .kb-header {
        text-align: center;
        margin-bottom: 1.5rem;
    }

    .kb-header h2 {
        color: #333;
        margin-bottom: 0.3rem;
    }

    .kb-subtitle {
        color: #888;
        font-size: 0.95rem;
    }

    .kb-search {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        margin-bottom: 1.5rem;
    }

    .search-box {
        display: flex;
        gap: 0.5rem;
    }

    .search-box input {
        flex: 1;
        padding: 0.8rem 1rem;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 1rem;
        outline: none;
        transition: border-color 0.2s;
    }

    .search-box input:focus {
        border-color: #667eea;
    }

    .search-box button {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 0.8rem 1.5rem;
        cursor: pointer;
        font-size: 0.95rem;
        white-space: nowrap;
    }

    .search-box button:hover:not(:disabled) {
        opacity: 0.9;
    }

    .search-box button:disabled {
        opacity: 0.5;
        cursor: default;
    }

    .quick-questions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 1rem;
        align-items: center;
    }

    .quick-label {
        color: #888;
        font-size: 0.85rem;
    }

    .quick-btn {
        background: #f5f5f5;
        border: 1px solid #e0e0e0;
        border-radius: 16px;
        padding: 0.3rem 0.8rem;
        cursor: pointer;
        font-size: 0.8rem;
        transition: all 0.2s;
    }

    .quick-btn:hover {
        background: #667eea;
        color: white;
        border-color: #667eea;
    }

    .kb-results {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        margin-bottom: 1.5rem;
    }

    .results-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .results-header h3 {
        margin: 0;
        color: #333;
    }

    .results-count {
        color: #888;
        font-size: 0.85rem;
    }

    .result-card {
        border: 1px solid #eee;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 0.8rem;
        transition: box-shadow 0.2s;
    }

    .result-card:hover {
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    .result-meta {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.5rem;
    }

    .result-source {
        color: #667eea;
        font-size: 0.85rem;
        font-weight: 500;
    }

    .result-score {
        color: #888;
        font-size: 0.8rem;
    }

    .result-content {
        color: #444;
        line-height: 1.6;
        white-space: pre-wrap;
    }

    .no-results {
        text-align: center;
        padding: 2rem;
        color: #888;
    }

    .no-results-icon {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
    }

    .kb-stats {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }

    .kb-stats h3 {
        margin: 0 0 1rem 0;
        color: #333;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }

    .stat-card {
        background: #f7f8fa;
        border-radius: 8px;
        padding: 1rem;
        text-align: center;
    }

    .stat-value {
        display: block;
        font-size: 1.8rem;
        font-weight: 700;
        color: #667eea;
    }

    .stat-label {
        display: block;
        font-size: 0.85rem;
        color: #888;
        margin-top: 0.3rem;
    }
</style>

@code {
    private string searchQuery = string.Empty;
    private bool isSearching;
    private RagQueryResponse? searchResult;
    private int knowledgeDocCount = 6;
    private int searchCount;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(searchQuery) && !isSearching)
        {
            await Search();
        }
    }

    private async Task QuickSearch(string query)
    {
        searchQuery = query;
        await Search();
    }

    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(searchQuery) || isSearching) return;

        isSearching = true;
        StateHasChanged();

        try
        {
            var request = new MafTaskRequest
            {
                TaskId = Guid.NewGuid().ToString(),
                UserInput = searchQuery.Trim(),
                Parameters = new Dictionary<string, object>()
            };

            var response = await KnowledgeAgent.ExecuteBusinessLogicAsync(request);

            // 同时获取原始检索结果用于展示
            var ragRequest = new RagQueryRequest
            {
                Query = searchQuery.Trim(),
                CollectionName = KnowledgeBaseAgent.CollectionName,
                TopK = 3,
                ScoreThreshold = 0.3f
            };
            searchResult = await RagPipeline.QueryAsync(ragRequest);
            searchCount++;
        }
        catch (Exception)
        {
            searchResult = new RagQueryResponse();
        }
        finally
        {
            isSearching = false;
            StateHasChanged();
        }
    }
}
