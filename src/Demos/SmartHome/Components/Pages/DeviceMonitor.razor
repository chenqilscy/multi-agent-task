@page "/device-monitor"
@using CKY.MultiAgentFramework.Demos.SmartHome.Services
@using CKY.MultiAgentFramework.Demos.SmartHome.Models
@rendermode InteractiveServer
@inject ISensorDataService SensorDataService
@inject SmartHomeControlService ControlService

<PageTitle>设备监控 - 智能家居</PageTitle>

<div class="monitor-container">
    <h2>📊 设备数据监控</h2>

    <div class="room-tabs">
        @foreach (var room in rooms)
        {
            <button class="tab @(selectedRoom == room ? "active" : "")"
                    @onclick="() => SelectRoom(room)">@room</button>
        }
    </div>

    @if (isLoading)
    {
        <div class="loading">加载数据中...</div>
    }
    else
    {
        <!-- 当前状态卡片 -->
        <div class="status-grid">
            <div class="status-card temp">
                <div class="card-icon">🌡️</div>
                <div class="card-value">@currentTemp.ToString("F1")°C</div>
                <div class="card-label">当前温度</div>
            </div>
            <div class="status-card humidity">
                <div class="card-icon">💧</div>
                <div class="card-value">@currentHumidity.ToString("F0")%</div>
                <div class="card-label">当前湿度</div>
            </div>
            <div class="status-card trend">
                <div class="card-icon">@(tempTrend >= 0 ? "📈" : "📉")</div>
                <div class="card-value">@(tempTrend >= 0 ? "+" : "")@tempTrend.ToString("F1")°C</div>
                <div class="card-label">24h 趋势</div>
            </div>
            <div class="status-card range">
                <div class="card-icon">📏</div>
                <div class="card-value">@minTemp.ToString("F1") ~ @maxTemp.ToString("F1")</div>
                <div class="card-label">温度范围 (7天)</div>
            </div>
        </div>

        <!-- 温度柱状图 -->
        <div class="chart-section">
            <h3>🌡️ @selectedRoom 近 7 天温度变化</h3>
            <div class="bar-chart">
                @foreach (var point in chartData)
                {
                    var barHeight = Math.Max(5, (point.Temperature - chartMin) / (chartMax - chartMin) * 100.0);
                    var barColor = point.Temperature > 28 ? "#ef5350" :
                                   point.Temperature < 18 ? "#42a5f5" : "#66bb6a";
                    <div class="bar-group">
                        <div class="bar-value">@point.Temperature.ToString("F1")°</div>
                        <div class="bar" style="height: @barHeight.ToString("F0")%; background: @barColor"></div>
                        <div class="bar-label">@point.Timestamp.ToString("MM/dd")</div>
                    </div>
                }
            </div>
            @if (chartData.Count == 0)
            {
                <div class="no-data">暂无传感器数据</div>
            }
        </div>

        <!-- 设备状态 -->
        <div class="chart-section">
            <h3>🏠 @selectedRoom 设备状态</h3>
            <div class="device-grid">
                @foreach (var device in roomDevices)
                {
                    <div class="device-card @(device.IsOn ? "on" : "off")">
                        <div class="device-icon">@GetDeviceIcon(device.DeviceName)</div>
                        <div class="device-name">@device.DeviceName</div>
                        <div class="device-status">@(device.IsOn ? "运行中" : "已关闭")</div>
                        @if (device.Value != null)
                        {
                            <div class="device-value">@device.Value</div>
                        }
                    </div>
                }
                @if (roomDevices.Count == 0)
                {
                    <div class="no-data">该房间暂无设备信息</div>
                }
            </div>
        </div>
    }
</div>

<style>
    .monitor-container { max-width: 1000px; margin: 20px auto; padding: 0 16px; }
    .monitor-container h2 { margin-bottom: 16px; color: #333; }
    .room-tabs { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
    .tab { padding: 8px 18px; border: 1px solid #ddd; border-radius: 20px; background: white; cursor: pointer; font-size: 0.9rem; transition: all 0.2s; }
    .tab.active { background: #667eea; color: white; border-color: #667eea; }
    .tab:hover:not(.active) { background: #f0f0ff; border-color: #667eea; }
    .loading, .no-data { text-align: center; padding: 30px; color: #999; }

    .status-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; margin-bottom: 24px; }
    .status-card { background: white; border: 1px solid #e0e0e0; border-radius: 10px; padding: 16px; text-align: center; }
    .status-card.temp { border-top: 3px solid #ff7043; }
    .status-card.humidity { border-top: 3px solid #42a5f5; }
    .status-card.trend { border-top: 3px solid #66bb6a; }
    .status-card.range { border-top: 3px solid #ab47bc; }
    .card-icon { font-size: 1.5rem; margin-bottom: 4px; }
    .card-value { font-size: 1.4rem; font-weight: 700; color: #333; }
    .card-label { font-size: 0.8rem; color: #999; margin-top: 2px; }

    .chart-section { background: white; border: 1px solid #e0e0e0; border-radius: 10px; padding: 20px; margin-bottom: 20px; }
    .chart-section h3 { margin: 0 0 16px; font-size: 1rem; color: #444; }

    .bar-chart { display: flex; align-items: flex-end; justify-content: space-around; height: 200px; border-bottom: 2px solid #eee; padding: 10px 0; }
    .bar-group { display: flex; flex-direction: column; align-items: center; flex: 1; max-width: 60px; }
    .bar-value { font-size: 0.7rem; color: #666; margin-bottom: 4px; }
    .bar { width: 30px; border-radius: 4px 4px 0 0; transition: height 0.5s ease; min-height: 10px; }
    .bar-label { font-size: 0.7rem; color: #999; margin-top: 6px; }

    .device-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; }
    .device-card { border: 1px solid #e0e0e0; border-radius: 8px; padding: 14px; text-align: center; transition: all 0.2s; }
    .device-card.on { border-color: #66bb6a; background: #f1f8e9; }
    .device-card.off { background: #fafafa; }
    .device-icon { font-size: 1.8rem; margin-bottom: 6px; }
    .device-name { font-size: 0.85rem; font-weight: 500; }
    .device-status { font-size: 0.75rem; color: #999; margin-top: 2px; }
    .device-card.on .device-status { color: #4caf50; }
    .device-value { font-size: 0.75rem; color: #667eea; margin-top: 4px; }
</style>

@code {
    private readonly string[] rooms = ["客厅", "卧室", "厨房", "书房"];
    private string selectedRoom = "客厅";
    private bool isLoading = true;

    private double currentTemp;
    private double currentHumidity;
    private double tempTrend;
    private double minTemp;
    private double maxTemp;
    private double chartMin;
    private double chartMax;
    private List<TemperatureRecord> chartData = new();
    private List<DeviceStatus> roomDevices = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadRoomData();
    }

    private async Task SelectRoom(string room)
    {
        selectedRoom = room;
        await LoadRoomData();
    }

    private async Task LoadRoomData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            // 加载温度历史
            var records = await SensorDataService.GetTemperatureHistoryAsync(selectedRoom, 7);
            chartData = records;

            if (records.Count > 0)
            {
                var temps = records.Select(r => r.Temperature).ToList();
                currentTemp = records.Last().Temperature;
                currentHumidity = records.Last().Humidity;
                minTemp = temps.Min();
                maxTemp = temps.Max();
                chartMin = minTemp - 2;
                chartMax = maxTemp + 2;

                // 24h 趋势
                if (records.Count >= 2)
                {
                    var recent = records.TakeLast(Math.Min(records.Count, 24)).ToList();
                    tempTrend = Math.Round(recent.Last().Temperature - recent.First().Temperature, 1);
                }
            }

            // 加载设备状态
            var allDevices = await ControlService.GetAllDeviceStatusAsync();
            if (allDevices.TryGetValue(selectedRoom, out var devices))
            {
                roomDevices = devices;
            }
            else
            {
                roomDevices = allDevices.Values.SelectMany(d => d)
                    .Where(d => d.Room.Contains(selectedRoom))
                    .ToList();
            }
        }
        catch
        {
            chartData = new();
            roomDevices = new();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private static string GetDeviceIcon(string name) => name switch
    {
        _ when name.Contains("灯") || name.Contains("光") => "💡",
        _ when name.Contains("空调") || name.Contains("温") => "🌡️",
        _ when name.Contains("音") || name.Contains("乐") => "🎵",
        _ when name.Contains("锁") || name.Contains("门") => "🔒",
        _ when name.Contains("窗帘") => "🪟",
        _ when name.Contains("摄像") => "📷",
        _ => "🏠"
    };
}
