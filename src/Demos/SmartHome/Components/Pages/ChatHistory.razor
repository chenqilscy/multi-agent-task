@page "/chat-history"
@using CKY.MultiAgentFramework.Demos.SmartHome.Services
@rendermode InteractiveServer
@inject IServiceProvider ServiceProvider

<PageTitle>对话历史 - 智能家居</PageTitle>

<div class="history-container">
    <div class="history-header">
        <h2>📜 对话历史</h2>
        <button class="btn-refresh" @onclick="LoadSessions">🔄 刷新</button>
    </div>

    @if (isLoading)
    {
        <div class="loading">加载中...</div>
    }
    else if (sessions.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">💬</div>
            <p>暂无对话记录</p>
            <a href="chat" class="link-btn">开始新对话</a>
        </div>
    }
    else
    {
        <div class="session-list">
            @foreach (var session in sessions)
            {
                <div class="session-card @(selectedSessionId == session.SessionId ? "active" : "")"
                     @onclick="() => LoadMessages(session.SessionId)">
                    <div class="session-header">
                        <span class="session-id">@session.SessionId[..8]...</span>
                        <span class="session-time">@session.CreatedAt.ToString("MM-dd HH:mm")</span>
                    </div>
                    <div class="session-preview">@session.Preview</div>
                    <div class="session-meta">@session.MessageCount 条消息</div>
                </div>
            }
        </div>

        @if (selectedMessages.Count > 0)
        {
            <div class="message-panel">
                <div class="panel-header">
                    <h3>对话内容</h3>
                    <span class="msg-count">@selectedMessages.Count 条消息</span>
                </div>
                <div class="message-list">
                    @foreach (var msg in selectedMessages)
                    {
                        <div class="msg @(msg.Role == "User" ? "msg-user" : "msg-assistant")">
                            <div class="msg-avatar">@(msg.Role == "User" ? "👤" : "🤖")</div>
                            <div class="msg-body">
                                <div class="msg-text">@msg.Content</div>
                                <div class="msg-time">@msg.CreatedAt</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

<style>
    .history-container { max-width: 1000px; margin: 20px auto; padding: 0 16px; }
    .history-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .history-header h2 { margin: 0; color: #333; }
    .btn-refresh { background: #667eea; color: white; border: none; padding: 6px 14px; border-radius: 6px; cursor: pointer; font-size: 0.85rem; }
    .btn-refresh:hover { background: #5a6fd6; }
    .loading, .empty-state { text-align: center; padding: 40px; color: #999; }
    .empty-icon { font-size: 3rem; margin-bottom: 10px; }
    .link-btn { display: inline-block; margin-top: 10px; padding: 8px 20px; background: #667eea; color: white; text-decoration: none; border-radius: 6px; }
    .session-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
    .session-card { background: white; border: 1px solid #e0e0e0; border-radius: 8px; padding: 12px 16px; cursor: pointer; transition: all 0.2s; }
    .session-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .session-card.active { border-color: #667eea; background: #f0f0ff; }
    .session-header { display: flex; justify-content: space-between; margin-bottom: 4px; }
    .session-id { font-family: monospace; font-size: 0.8rem; color: #999; }
    .session-time { font-size: 0.8rem; color: #999; }
    .session-preview { font-size: 0.9rem; color: #555; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .session-meta { font-size: 0.75rem; color: #bbb; margin-top: 4px; }
    .message-panel { background: white; border: 1px solid #e0e0e0; border-radius: 10px; overflow: hidden; }
    .panel-header { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: #f5f5f5; border-bottom: 1px solid #e0e0e0; }
    .panel-header h3 { margin: 0; font-size: 1rem; }
    .msg-count { font-size: 0.8rem; color: #999; }
    .message-list { padding: 16px; display: flex; flex-direction: column; gap: 10px; max-height: 500px; overflow-y: auto; }
    .msg { display: flex; gap: 8px; max-width: 85%; }
    .msg-user { align-self: flex-end; flex-direction: row-reverse; }
    .msg-assistant { align-self: flex-start; }
    .msg-avatar { font-size: 1.2rem; flex-shrink: 0; }
    .msg-body { border-radius: 10px; padding: 8px 12px; }
    .msg-user .msg-body { background: #667eea; color: white; }
    .msg-assistant .msg-body { background: #f0f0f0; }
    .msg-text { white-space: pre-wrap; line-height: 1.4; font-size: 0.9rem; }
    .msg-time { font-size: 0.7rem; opacity: 0.6; margin-top: 3px; text-align: right; }
</style>

@code {
    private List<SessionSummary> sessions = new();
    private List<ChatHistoryMessage> selectedMessages = new();
    private string? selectedSessionId;
    private bool isLoading = true;

    private class SessionSummary
    {
        public string SessionId { get; set; } = "";
        public DateTime CreatedAt { get; set; }
        public string Preview { get; set; } = "";
        public int MessageCount { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSessions();
    }

    private async Task LoadSessions()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            using var scope = ServiceProvider.CreateScope();
            var chatHistory = scope.ServiceProvider.GetService<SmartHomeChatHistoryService>();
            if (chatHistory == null)
            {
                sessions = new();
                return;
            }

            // 加载所有会话（通过查询 MafAiSessions 表）
            var db = scope.ServiceProvider.GetRequiredService<CKY.MultiAgentFramework.Core.Abstractions.IRelationalDatabase>();
            var sessionRows = await db.ExecuteSqlAsync<SessionRow>(
                "SELECT SessionId, CreatedAt FROM MafAiSessions WHERE UserId = @UserId ORDER BY CreatedAt DESC LIMIT 50",
                new { UserId = "smarthome-demo" });

            sessions = new();
            foreach (var row in sessionRows)
            {
                var msgs = await chatHistory.LoadMessagesAsync(row.SessionId, limit: 1);
                sessions.Add(new SessionSummary
                {
                    SessionId = row.SessionId,
                    CreatedAt = DateTime.TryParse(row.CreatedAt, out var dt) ? dt : DateTime.MinValue,
                    Preview = msgs.FirstOrDefault()?.Content ?? "(空会话)",
                    MessageCount = (await chatHistory.LoadMessagesAsync(row.SessionId, limit: 200)).Count
                });
            }
        }
        catch
        {
            sessions = new();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadMessages(string sessionId)
    {
        selectedSessionId = sessionId;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var chatHistory = scope.ServiceProvider.GetService<SmartHomeChatHistoryService>();
            if (chatHistory != null)
            {
                selectedMessages = await chatHistory.LoadMessagesAsync(sessionId, limit: 200);
            }
        }
        catch
        {
            selectedMessages = new();
        }
        StateHasChanged();
    }

    private class SessionRow
    {
        public string SessionId { get; set; } = "";
        public string CreatedAt { get; set; } = "";
    }
}
