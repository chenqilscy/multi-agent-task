<div class="music-panel">
    <div class="player-header">
        <h4>🎵 音乐播放器</h4>
        <div class="status-indicator @(isPlaying ? "status-playing" : "status-stopped")">
            @(isPlaying ? "播放中" : "已停止")
        </div>
    </div>

    @if (isPlaying)
    {
        <div class="now-playing">
            <div class="song-info">
                <p class="song-title">@currentSong</p>
                <p class="artist-name">系统播放列表</p>
            </div>
        </div>
    }

    <div class="player-controls">
        <button class="control-btn" @onclick="PlayMusic" disabled="@isPlaying" title="播放">
            ▶️
        </button>
        <button class="control-btn" @onclick="PauseMusic" disabled="!isPlaying" title="暂停">
            ⏸️
        </button>
        <button class="control-btn" @onclick="NextSong" title="下一首">
            ⏭️
        </button>
    </div>

    <div class="volume-control">
        <label>音量</label>
        <input type="range" min="0" max="100" @bind="volume" />
        <span class="volume-value">@volume%</span>
    </div>

    <div class="playlist-section">
        <h5>播放列表</h5>
        <ul class="playlist">
            @for (int i = 0; i < playlist.Length; i++)
            {
                <li class="@(currentSongIndex == i ? "active" : "")" @onclick="() => PlaySong(i)">
                    <span class="song-index">@(i + 1)</span>
                    <span class="song-name">@playlist[i]</span>
                </li>
            }
        </ul>
    </div>
</div>

@code {
    private bool isPlaying = false;
    private string currentSong = "轻柔背景音乐";
    private int volume = 50;
    private int currentSongIndex = 0;
    private readonly string[] playlist = new[]
    {
        "轻柔背景音乐",
        "晨间唤醒曲",
        "专注工作音乐",
        "放松冥想曲",
        "晚间助眠音乐"
    };

    private void PlayMusic()
    {
        isPlaying = true;
        // 在实际应用中，这里会调用音乐服务
    }

    private void PauseMusic()
    {
        isPlaying = false;
    }

    private void NextSong()
    {
        currentSongIndex = (currentSongIndex + 1) % playlist.Length;
        currentSong = playlist[currentSongIndex];
    }

    private void PlaySong(int index)
    {
        currentSongIndex = index;
        currentSong = playlist[index];
        isPlaying = true;
    }
}
