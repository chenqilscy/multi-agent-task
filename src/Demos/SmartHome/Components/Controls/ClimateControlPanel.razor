@using CKY.MultiAgentFramework.Demos.SmartHome.Services
@inject IClimateService ClimateService

<div class="climate-panel">
    <div class="room-header">
        <h4>@Room</h4>
        <div class="status-indicator @(isOn ? "status-on" : "status-off")">
            @(isOn ? "运行中" : "已关闭")
        </div>
    </div>

    <div class="temperature-control">
        <label>温度设定</label>
        <div class="temp-controls">
            <button class="temp-btn" @onclick="@(() => AdjustTemperature(-1))">-</button>
            <span class="temp-display">@temperature°</span>
            <button class="temp-btn" @onclick="@(() => AdjustTemperature(1))">+</button>
        </div>
    </div>

    <div class="mode-controls">
        <label>运行模式</label>
        <div class="mode-buttons">
            <button class="mode-btn @(mode == "cooling" ? "active" : "")" @onclick="@(() => SetMode("cooling"))">
                ❄️ 制冷
            </button>
            <button class="mode-btn @(mode == "heating" ? "active" : "")" @onclick="@(() => SetMode("heating"))">
                🔥 制热
            </button>
            <button class="mode-btn @(mode == "auto" ? "active" : "")" @onclick="@(() => SetMode("auto"))">
                🔄 自动
            </button>
        </div>
    </div>

    <div class="quick-presets">
        <button class="preset-btn" @onclick="@(() => SetPreset(24, "cooling"))">舒适制冷</button>
        <button class="preset-btn" @onclick="@(() => SetPreset(26, "heating"))">舒适制热</button>
        <button class="preset-btn" @onclick="@(() => SetPreset(20, "cooling"))">强力制冷</button>
    </div>
</div>

@code {
    [Parameter]
    public string Room { get; set; } = "客厅";

    private bool isOn = false;
    private int temperature = 26;
    private string mode = "auto";

    private async Task SetMode(string newMode)
    {
        try
        {
            await ClimateService.SetModeAsync(Room, newMode);
            mode = newMode;
            isOn = true;
        }
        catch
        {
            // 处理错误
        }
    }

    private async Task AdjustTemperature(int delta)
    {
        temperature = Math.Clamp(temperature + delta, 16, 30);
        try
        {
            await ClimateService.SetTemperatureAsync(Room, temperature);
            isOn = true;
        }
        catch
        {
            // 处理错误
        }
    }

    private async Task SetPreset(int temp, string presetMode)
    {
        temperature = temp;
        await SetMode(presetMode);
        await ClimateService.SetTemperatureAsync(Room, temperature);
    }
}
