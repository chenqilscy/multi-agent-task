@page "/admin/dashboard"
@using CKY.MultiAgentFramework.Demos.CustomerService.Services
@rendermode InteractiveServer
@inject IServiceProvider ServiceProvider

<PageTitle>仪表盘 - 智能客服</PageTitle>

<div class="dashboard-container">
    <h2>📊 客服运营仪表盘</h2>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">📦</div>
            <div class="stat-value">@orderCount</div>
            <div class="stat-label">总订单数</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">📋</div>
            <div class="stat-value">@ticketCount</div>
            <div class="stat-label">工单总数</div>
        </div>
        <div class="stat-card highlight-red">
            <div class="stat-icon">🔴</div>
            <div class="stat-value">@openTicketCount</div>
            <div class="stat-label">待处理工单</div>
        </div>
        <div class="stat-card highlight-green">
            <div class="stat-icon">✅</div>
            <div class="stat-value">@resolvedTicketCount</div>
            <div class="stat-label">已解决工单</div>
        </div>
    </div>

    <div class="section">
        <h3>📋 最近工单</h3>
        @if (recentTickets.Count == 0)
        {
            <p class="empty">暂无工单数据</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>工单号</th>
                        <th>标题</th>
                        <th>类别</th>
                        <th>优先级</th>
                        <th>状态</th>
                        <th>时间</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in recentTickets)
                    {
                        <tr>
                            <td class="mono">@ticket.TicketId</td>
                            <td>@ticket.Title</td>
                            <td>@ticket.Category</td>
                            <td><span class="badge priority-@ticket.Priority">@ticket.Priority</span></td>
                            <td><span class="badge status-@ticket.Status">@GetStatusText(ticket.Status)</span></td>
                            <td>@ticket.CreatedAt.ToString("MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="section">
        <h3>📦 最近订单</h3>
        @if (recentOrders.Count == 0)
        {
            <p class="empty">暂无订单数据</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>订单号</th>
                        <th>用户</th>
                        <th>金额</th>
                        <th>状态</th>
                        <th>时间</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in recentOrders)
                    {
                        <tr>
                            <td class="mono">@order.OrderId</td>
                            <td>@order.UserId</td>
                            <td>¥@order.TotalAmount.ToString("N2")</td>
                            <td><span class="badge">@order.Status</span></td>
                            <td>@order.CreatedAt.ToString("MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<style>
    .dashboard-container { max-width: 1100px; margin: 20px auto; padding: 0 16px; }
    .dashboard-container h2 { margin-bottom: 20px; color: #333; }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 30px; }
    .stat-card { background: white; border: 1px solid #e0e0e0; border-radius: 10px; padding: 20px; text-align: center; }
    .stat-card.highlight-red { border-color: #ef9a9a; background: #ffebee; }
    .stat-card.highlight-green { border-color: #a5d6a7; background: #e8f5e9; }
    .stat-icon { font-size: 2rem; margin-bottom: 6px; }
    .stat-value { font-size: 2rem; font-weight: 700; color: #333; }
    .stat-label { font-size: 0.85rem; color: #999; margin-top: 4px; }
    .section { margin-bottom: 30px; }
    .section h3 { margin-bottom: 12px; color: #444; }
    .empty { color: #999; text-align: center; padding: 20px; }
    .data-table { width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; border: 1px solid #e0e0e0; }
    .data-table th { background: #f5f5f5; padding: 10px 14px; text-align: left; font-size: 0.85rem; color: #666; border-bottom: 1px solid #e0e0e0; }
    .data-table td { padding: 10px 14px; border-bottom: 1px solid #f0f0f0; font-size: 0.9rem; }
    .mono { font-family: monospace; font-size: 0.8rem; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 0.75rem; background: #e3f2fd; color: #1565c0; }
    .badge.priority-urgent { background: #ffebee; color: #c62828; }
    .badge.priority-high { background: #fff3e0; color: #e65100; }
    .badge.status-open { background: #ffebee; color: #c62828; }
    .badge.status-in_progress { background: #fff8e1; color: #f57f17; }
    .badge.status-resolved { background: #e8f5e9; color: #2e7d32; }
    .badge.status-closed { background: #f5f5f5; color: #757575; }
</style>

@code {
    private int orderCount;
    private int ticketCount;
    private int openTicketCount;
    private int resolvedTicketCount;
    private List<TicketInfo> recentTickets = new();
    private List<OrderInfo> recentOrders = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var ticketService = scope.ServiceProvider.GetRequiredService<ITicketService>();
            var orderService = scope.ServiceProvider.GetRequiredService<IOrderService>();

            // 加载工单统计
            var allTickets = new List<TicketInfo>();
            foreach (var userId in new[] { "demo-user-001", "demo-user-002", "demo-user-003" })
            {
                allTickets.AddRange(await ticketService.GetUserTicketsAsync(userId));
            }
            ticketCount = allTickets.Count;
            openTicketCount = allTickets.Count(t => t.Status == "open");
            resolvedTicketCount = allTickets.Count(t => t.Status is "resolved" or "closed");
            recentTickets = allTickets.OrderByDescending(t => t.CreatedAt).Take(10).ToList();

            // 加载订单统计
            var allOrders = new List<OrderInfo>();
            foreach (var userId in new[] { "demo-user-001", "demo-user-002", "demo-user-003" })
            {
                allOrders.AddRange(await orderService.GetUserOrdersAsync(userId));
            }
            orderCount = allOrders.Count;
            recentOrders = allOrders.OrderByDescending(o => o.CreatedAt).Take(10).ToList();
        }
        catch
        {
            // 统计加载失败时保持默认值
        }
    }

    private static string GetStatusText(string status) => status switch
    {
        "open" => "待处理",
        "in_progress" => "处理中",
        "resolved" => "已解决",
        "closed" => "已关闭",
        _ => status
    };
}
