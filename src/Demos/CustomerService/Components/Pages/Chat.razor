@page "/"
@page "/chat"
@using CKY.MultiAgentFramework.Core.Models.Task
@using CKY.MultiAgentFramework.Demos.CustomerService.Agents
@using CKY.MultiAgentFramework.Demos.CustomerService.Models
@using CKY.MultiAgentFramework.Demos.CustomerService.Services
@inject CustomerServiceLeaderAgent LeaderAgent
@inject IServiceProvider ServiceProvider
@rendermode InteractiveServer

<PageTitle>智能客服</PageTitle>

<div class="chat-container">
    <div class="chat-header">
        <h2>🤖 CKY 智能客服</h2>
        <p class="subtitle">随时为您提供订单查询、退款申请、常见问题解答等服务</p>
    </div>

    <!-- 快捷功能入口 -->
    <div class="quick-actions">
        <button class="quick-btn" @onclick="@(() => SendMessage("查询我的最近订单"))">📦 查询订单</button>
        <button class="quick-btn" @onclick="@(() => SendMessage("如何申请退款？"))">💰 申请退款</button>
        <button class="quick-btn" @onclick="@(() => SendMessage("我要提交工单"))">📝 提交工单</button>
        <button class="quick-btn" @onclick="@(() => SendMessage("快递到哪了？"))">🚚 物流查询</button>
        <button class="quick-btn handoff-btn" @onclick="RequestHumanHandoff" disabled="@isHandoffRequested">👨‍💼 转人工客服</button>
    </div>

    <!-- 对话区域 -->
    <div class="chat-messages" id="chatMessages">
        @foreach (ChatMessage msg in messages)
        {
            <div class="message @(msg.IsUser ? "user-message" : "assistant-message")">
                @if (!msg.IsUser)
                {
                    <div class="avatar">🤖</div>
                }
                <div class="message-bubble">
                    <div class="message-content">@((MarkupString)SanitizeForHtml(msg.Content))</div>
                    <div class="message-time">@msg.Timestamp.ToString("HH:mm")</div>
                </div>
                @if (msg.IsUser)
                {
                    <div class="avatar">👤</div>
                }
            </div>
        }

        @if (isProcessing)
        {
            <div class="message assistant-message">
                <div class="avatar">🤖</div>
                <div class="message-bubble">
                    <div class="typing-indicator">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            </div>
        }

        @if (clarificationOptions.Count > 0)
        {
            <div class="clarification-options">
                @foreach (var option in clarificationOptions)
                {
                    <button class="option-btn" @onclick="@(() => SendMessage(option))">@option</button>
                }
            </div>
        }
    </div>

    <!-- 输入区域 -->
    <div class="chat-input">
        <input @bind="userInput"
               @bind:event="oninput"
               @onkeypress="HandleKeyPress"
               maxlength="500"
               placeholder="请输入您的问题，例如：查询订单 ORD-2024-001"
               disabled="@isProcessing" />
        <button @onclick="() => SendMessage(userInput)"
                disabled="@(string.IsNullOrWhiteSpace(userInput) || isProcessing)">
            发送
        </button>
    </div>
</div>

<style>
    .chat-container {
        max-width: 800px;
        margin: 20px auto;
        display: flex;
        flex-direction: column;
        height: calc(100vh - 100px);
        border: 1px solid #e0e0e0;
        border-radius: 12px;
        overflow: hidden;
        background: #f9f9f9;
    }
    .chat-header {
        background: linear-gradient(135deg, #1976d2, #42a5f5);
        color: white;
        padding: 16px 20px;
        text-align: center;
    }
    .chat-header h2 { margin: 0; font-size: 1.4rem; }
    .chat-header .subtitle { margin: 4px 0 0; font-size: 0.85rem; opacity: 0.9; }
    .quick-actions {
        display: flex;
        gap: 8px;
        padding: 10px 16px;
        background: white;
        border-bottom: 1px solid #eee;
        flex-wrap: wrap;
    }
    .quick-btn {
        padding: 6px 14px;
        border: 1px solid #1976d2;
        border-radius: 20px;
        background: white;
        color: #1976d2;
        cursor: pointer;
        font-size: 0.85rem;
        transition: all 0.2s;
    }
    .quick-btn:hover { background: #1976d2; color: white; }
    .handoff-btn { border-color: #ff9800; color: #e65100; }
    .handoff-btn:hover { background: #ff9800; color: white; border-color: #ff9800; }
    .handoff-btn:disabled { opacity: 0.5; cursor: default; }
    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .message {
        display: flex;
        align-items: flex-end;
        gap: 8px;
    }
    .user-message { flex-direction: row-reverse; }
    .avatar { font-size: 1.5rem; flex-shrink: 0; }
    .message-bubble {
        max-width: 70%;
        border-radius: 12px;
        padding: 10px 14px;
    }
    .user-message .message-bubble { background: #1976d2; color: white; border-radius: 12px 12px 0 12px; }
    .assistant-message .message-bubble { background: white; border: 1px solid #e0e0e0; border-radius: 12px 12px 12px 0; }
    .message-time { font-size: 0.7rem; opacity: 0.6; margin-top: 4px; text-align: right; }
    .typing-indicator { display: flex; gap: 4px; padding: 4px; }
    .typing-indicator span {
        width: 8px; height: 8px; border-radius: 50%;
        background: #aaa; animation: typing 1s infinite;
    }
    .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
    .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes typing { 0%, 60%, 100% { transform: translateY(0); } 30% { transform: translateY(-8px); } }
    .clarification-options {
        display: flex; gap: 8px; flex-wrap: wrap; padding: 8px 0;
    }
    .option-btn {
        padding: 6px 16px; border: 1px solid #42a5f5;
        border-radius: 20px; background: white; color: #1976d2;
        cursor: pointer; font-size: 0.9rem;
    }
    .option-btn:hover { background: #e3f2fd; }
    .chat-input {
        display: flex;
        gap: 8px;
        padding: 12px 16px;
        background: white;
        border-top: 1px solid #eee;
    }
    .chat-input input {
        flex: 1; padding: 10px 14px;
        border: 1px solid #ddd; border-radius: 24px;
        outline: none; font-size: 0.95rem;
    }
    .chat-input input:focus { border-color: #1976d2; }
    .chat-input button {
        padding: 10px 20px; background: #1976d2; color: white;
        border: none; border-radius: 24px; cursor: pointer; font-size: 0.95rem;
    }
    .chat-input button:disabled { opacity: 0.5; cursor: not-allowed; }
    .chat-input button:hover:not(:disabled) { background: #1565c0; }
</style>

@code {
    private string userInput = string.Empty;
    private bool isProcessing = false;
    private bool isHandoffRequested = false;
    private List<string> clarificationOptions = new();
    // 每个用户会话使用独立 SessionId，生产环境应从认证系统获取
    private readonly string sessionId = Guid.NewGuid().ToString();
    // 持久化会话 ID（通过 IChatHistoryService 创建）
    private string? persistentSessionId;
    private IChatHistoryService? chatHistoryService;
    private List<ChatMessage> messages = new()
    {
        new ChatMessage
        {
            IsUser = false,
            Content = "您好！我是 CKY 智能客服助手 🤖\n\n我可以帮您：\n• 📦 查询/取消订单\n• 🚚 查询物流信息\n• 💰 申请退款退货\n• 📝 提交客服工单\n• ❓ 回答常见问题\n\n请问有什么可以帮您？",
            Timestamp = DateTime.Now,
        }
    };

    private class ChatMessage
    {
        public bool IsUser { get; set; }
        public string Content { get; set; } = string.Empty;
        public DateTime Timestamp { get; set; } = DateTime.Now;
    }

    protected override async Task OnInitializedAsync()
    {
        // 尝试获取对话历史服务并创建持久化会话
        try
        {
            chatHistoryService = ServiceProvider.GetService(typeof(IChatHistoryService)) as IChatHistoryService;
            if (chatHistoryService != null)
            {
                persistentSessionId = await chatHistoryService.CreateSessionAsync("demo-user-001");
            }
        }
        catch
        {
            // 持久化服务不可用时静默降级
        }
    }
    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(userInput) && !isProcessing)
            await SendMessage(userInput);
    }

    private async Task SendMessage(string message)
    {
        if (string.IsNullOrWhiteSpace(message) || isProcessing)
            return;

        var input = message.Trim();
        // 服务端输入长度限制（防止绕过客户端限制）
        if (input.Length > 500)
            input = input[..500];
        userInput = string.Empty;
        clarificationOptions.Clear();
        isProcessing = true;

        // 添加用户消息
        messages.Add(new ChatMessage { IsUser = true, Content = input, Timestamp = DateTime.Now });
        StateHasChanged();

        // 持久化用户消息
        await SaveMessageAsync("user", input);

        try
        {
            var request = new MafTaskRequest
            {
                TaskId = Guid.NewGuid().ToString(),
                UserInput = input,
                // TODO: 生产环境中应从用户认证信息动态获取
                ConversationId = sessionId,
                UserId = "demo-user-001",
            };

            var response = await LeaderAgent.ExecuteBusinessLogicAsync(request);

            var assistantContent = response.Result ?? "抱歉，处理您的请求时出现问题。";

            // 处理澄清流程
            if (response.NeedsClarification && !string.IsNullOrEmpty(response.ClarificationQuestion))
            {
                assistantContent = response.ClarificationQuestion;
                clarificationOptions = response.ClarificationOptions;
            }

            messages.Add(new ChatMessage
            {
                IsUser = false,
                Content = assistantContent,
                Timestamp = DateTime.Now,
            });

            // 持久化助手回复
            await SaveMessageAsync("assistant", assistantContent);
        }
        catch (Exception)
        {
            var errorContent = "系统繁忙，请稍后重试。";
            messages.Add(new ChatMessage
            {
                IsUser = false,
                Content = errorContent,
                Timestamp = DateTime.Now,
            });
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task SaveMessageAsync(string role, string content)
    {
        if (string.IsNullOrEmpty(persistentSessionId) || chatHistoryService == null) return;
        try
        {
            await chatHistoryService.SaveMessageAsync(
                persistentSessionId, role, content);
        }
        catch
        {
            // 持久化失败不影响对话流程
        }
    }

    /// <summary>
    /// HTML 编码后保留换行符，防止 XSS 攻击
    /// </summary>
    private static string SanitizeForHtml(string content)
    {
        return System.Net.WebUtility.HtmlEncode(content).Replace("\n", newValue: "<br/>");
    }

    private async Task RequestHumanHandoff()
    {
        if (isHandoffRequested) return;

        isHandoffRequested = true;

        // 创建转人工工单
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var ticketService = scope.ServiceProvider.GetRequiredService<ITicketService>();
            var ticketId = await ticketService.CreateTicketAsync(new TicketCreateRequest
            {
                UserId = "demo-user-001",
                Title = "客户请求转接人工客服",
                Description = "客户在智能客服对话中请求转接人工坐席处理",
                Category = "other",
                Priority = "high"
            });

            messages.Add(new ChatMessage
            {
                IsUser = false,
                Content = $"已为您创建人工服务工单（{ticketId}），客服人员将尽快与您联系。\n\n工作时间：周一至周五 9:00-18:00\n预计响应时间：30 分钟内\n\n在等待期间，您仍可继续使用智能客服。",
                Timestamp = DateTime.Now,
            });
        }
        catch
        {
            messages.Add(new ChatMessage
            {
                IsUser = false,
                Content = "转接人工客服请求已记录，客服人员将尽快与您联系。",
                Timestamp = DateTime.Now,
            });
        }

        StateHasChanged();
    }
}
