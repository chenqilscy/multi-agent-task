@page "/admin/faq"
@using CKY.MultiAgentFramework.Demos.CustomerService.Services
@rendermode InteractiveServer
@inject IServiceProvider ServiceProvider

<PageTitle>知识库管理 - 智能客服</PageTitle>

<div class="admin-container">
    <div class="admin-header">
        <h2>📚 知识库管理</h2>
        <button class="btn btn-primary" @onclick="ShowAddForm">➕ 新增 FAQ</button>
    </div>

    @if (isLoading)
    {
        <div class="loading">加载中...</div>
    }
    else
    {
        <div class="search-box">
            <input @bind="searchQuery" @bind:event="oninput" placeholder="搜索知识库条目..." maxlength="200" />
            <button class="btn btn-search" @onclick="SearchFaq">🔍 搜索</button>
        </div>

        @if (faqEntries.Count == 0)
        {
            <div class="empty-state">暂无知识库条目，点击上方按钮添加</div>
        }
        else
        {
            <div class="faq-list">
                @foreach (var faq in faqEntries)
                {
                    <div class="faq-card">
                        <div class="faq-header">
                            <span class="faq-category">@faq.Category</span>
                            <span class="faq-id">@faq.Id</span>
                        </div>
                        <div class="faq-question">❓ @faq.Question</div>
                        <div class="faq-answer">@faq.Answer</div>
                        @if (faq.Keywords.Count > 0)
                        {
                            <div class="faq-keywords">
                                @foreach (var kw in faq.Keywords)
                                {
                                    <span class="keyword-tag">@kw</span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }

    @if (showForm)
    {
        <div class="form-overlay" @onclick="() => showForm = false">
            <div class="form-dialog" @onclick:stopPropagation="true">
                <h3>新增 FAQ 条目</h3>
                <div class="form-group">
                    <label>分类</label>
                    <select @bind="newFaq.Category">
                        <option value="订单">订单</option>
                        <option value="退款">退款</option>
                        <option value="物流">物流</option>
                        <option value="商品">商品</option>
                        <option value="账户">账户</option>
                        <option value="支付">支付</option>
                        <option value="其他">其他</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>问题</label>
                    <input @bind="newFaq.Question" maxlength="500" placeholder="输入常见问题..." />
                </div>
                <div class="form-group">
                    <label>答案</label>
                    <textarea @bind="newFaq.Answer" rows="5" maxlength="2000" placeholder="输入问题答案..."></textarea>
                </div>
                <div class="form-group">
                    <label>关键词（逗号分隔）</label>
                    <input @bind="keywordsInput" maxlength="500" placeholder="退款,退货,申请退款" />
                </div>
                <div class="form-actions">
                    <button class="btn btn-primary" @onclick="SaveFaq" disabled="@(!CanSave)">保存</button>
                    <button class="btn btn-secondary" @onclick="() => showForm = false">取消</button>
                </div>
                @if (!string.IsNullOrEmpty(formMessage))
                {
                    <div class="form-message @formMessageClass">@formMessage</div>
                }
            </div>
        </div>
    }
</div>

<style>
    .admin-container { max-width: 1000px; margin: 20px auto; padding: 0 16px; }
    .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .admin-header h2 { margin: 0; color: #333; }
    .loading, .empty-state { text-align: center; padding: 40px; color: #999; }
    .search-box { display: flex; gap: 8px; margin-bottom: 16px; }
    .search-box input { flex: 1; padding: 8px 14px; border: 1px solid #ddd; border-radius: 6px; }
    .btn { padding: 8px 16px; border: none; border-radius: 6px; cursor: pointer; font-size: 0.85rem; }
    .btn-primary { background: #1976d2; color: white; }
    .btn-secondary { background: #757575; color: white; }
    .btn-search { background: #42a5f5; color: white; }
    .btn:hover { opacity: 0.9; }
    .btn:disabled { opacity: 0.5; cursor: default; }
    .faq-list { display: flex; flex-direction: column; gap: 12px; }
    .faq-card { background: white; border: 1px solid #e0e0e0; border-radius: 8px; padding: 14px 16px; }
    .faq-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
    .faq-category { background: #e3f2fd; color: #1565c0; padding: 2px 10px; border-radius: 10px; font-size: 0.8rem; }
    .faq-id { font-size: 0.75rem; color: #999; font-family: monospace; }
    .faq-question { font-weight: 500; margin-bottom: 6px; color: #333; }
    .faq-answer { font-size: 0.9rem; color: #666; line-height: 1.5; white-space: pre-wrap; }
    .faq-keywords { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 8px; }
    .keyword-tag { background: #f5f5f5; border: 1px solid #e0e0e0; padding: 2px 8px; border-radius: 4px; font-size: 0.75rem; color: #666; }
    .form-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; justify-content: center; align-items: center; z-index: 1000; }
    .form-dialog { background: white; border-radius: 12px; padding: 24px; width: 90%; max-width: 600px; }
    .form-dialog h3 { margin: 0 0 16px; }
    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; font-size: 0.85rem; font-weight: 500; margin-bottom: 4px; color: #555; }
    .form-group input, .form-group textarea, .form-group select { width: 100%; padding: 8px 12px; border: 1px solid #ddd; border-radius: 6px; box-sizing: border-box; }
    .form-group textarea { resize: vertical; }
    .form-actions { display: flex; gap: 8px; margin-top: 16px; }
    .form-message { padding: 8px 12px; border-radius: 6px; margin-top: 10px; font-size: 0.85rem; }
    .form-message.success { background: #e8f5e9; color: #2e7d32; }
    .form-message.error { background: #ffebee; color: #c62828; }
</style>

@code {
    private List<FaqEntry> faqEntries = new();
    private string searchQuery = "";
    private bool isLoading = true;
    private bool showForm = false;
    private FaqEntry newFaq = new() { Category = "其他" };
    private string keywordsInput = "";
    private string formMessage = "";
    private string formMessageClass = "";

    private bool CanSave => !string.IsNullOrWhiteSpace(newFaq.Question) && !string.IsNullOrWhiteSpace(newFaq.Answer);

    protected override async Task OnInitializedAsync()
    {
        await LoadFaq();
    }

    private async Task LoadFaq()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            // 使用常见关键词搜索加载所有 FAQ
            using var scope = ServiceProvider.CreateScope();
            var kbService = scope.ServiceProvider.GetRequiredService<IKnowledgeBaseService>();
            var result = await kbService.SearchAsync("", topK: 100);
            faqEntries = result.RelevantFaqs;
        }
        catch
        {
            faqEntries = new();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SearchFaq()
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            await LoadFaq();
            return;
        }

        isLoading = true;
        StateHasChanged();

        try
        {
            using var scope = ServiceProvider.CreateScope();
            var kbService = scope.ServiceProvider.GetRequiredService<IKnowledgeBaseService>();
            var result = await kbService.SearchAsync(searchQuery.Trim(), topK: 20);
            faqEntries = result.RelevantFaqs;
        }
        catch
        {
            faqEntries = new();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ShowAddForm()
    {
        newFaq = new FaqEntry { Category = "其他" };
        keywordsInput = "";
        formMessage = "";
        showForm = true;
    }

    private async Task SaveFaq()
    {
        if (!CanSave) return;

        try
        {
            newFaq.Keywords = keywordsInput.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

            // 通过知识库服务保存（如果支持写入）
            // 作为 Demo，将新条目添加到内存列表展示
            newFaq.Id = $"FAQ-{DateTime.Now:yyyyMMddHHmmss}";
            faqEntries.Insert(0, newFaq);

            formMessage = "FAQ 条目已添加成功";
            formMessageClass = "success";
            StateHasChanged();

            await Task.Delay(1500);
            showForm = false;
        }
        catch (Exception)
        {
            formMessage = "保存失败，请重试";
            formMessageClass = "error";
        }
    }
}
