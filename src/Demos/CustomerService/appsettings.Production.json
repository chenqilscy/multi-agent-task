{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "MafFramework": "Host=postgres-server;Port=5432;Database=maframework;Username=maf_user;Password=your_secure_password;SSL Mode=Require;Pool Size=20;",
    "Redis": "redis-server:6379,password=your_redis_password,ssl=true"
  },
  "MafStorage": {
    "UseBuiltinImplementations": false,
    "RelationalDatabase": {
      "Provider": "PostgreSQL"
    }
  }
}
