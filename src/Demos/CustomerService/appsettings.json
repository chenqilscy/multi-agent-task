{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MafFramework": "Data Source=maf.db"
  },
  "MafStorage": {
    "UseBuiltinImplementations": false,
    "RelationalDatabase": {
      "Provider": "SQLite",
      "SqlitePath": "maf.db"
    }
  }
}
