{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MafFramework": "Data Source=maf.db",
    "CustomerService": "Data Source=customer_service.db"
  },
  "MafStorage": {
    "UseBuiltinImplementations": false,
    "RelationalDatabase": {
      "Provider": "SQLite",
      "SqlitePath": "maf.db"
    }
  },
  "CustomerService": {
    "Database": {
      "Provider": "SQLite"
    },
    "UsePersistentStorage": true
  }
}
